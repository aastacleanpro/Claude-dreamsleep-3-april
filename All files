### Auto-scaling with Swarm (manual trigger)
```bash
#!/bin/bash
# ops/scaling/auto-scale.sh

CPU_THRESHOLD=70
CURRENT_CPU=$(docker stats --no-stream --format "{{.CPUPerc}}" | awk '{sum+=$1} END {print sum/NR}')

if (( $(echo "$CURRENT_CPU > $CPU_THRESHOLD" | bc -l) )); then
    echo "📈 CPU above threshold ($CURRENT_CPU%), scaling up..."
    docker service scale ausclean_backend=+2
else
    echo "✅ CPU within limits ($CURRENT_CPU%)"
fi
